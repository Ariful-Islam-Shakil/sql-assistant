# .env.example
# Copy this file to .env and fill in the actual values.

# LLM provider selection (ollama, gemini, openrouter, groq)
LLM_PROVIDER=ollama

# Ollama host (used when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434

# Model names for planning and coding (adjust per provider)
PLANNER_MODEL=llama3.1:8b-instruct-q8_0
CODER_MODEL=qwen2.5-coder:7b-instruct-q8_0

# Database connection string (PostgreSQL example)
DATABASE_URL=postgresql://user:password@localhost:5432/database_name

# Optional API keys for alternative providers
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
