SELECT p.name,
       p.price,
       pi.image_path
FROM products p
JOIN brands b ON p.brand_id = b.id
JOIN categories c ON p.category_id = c.id
JOIN product_images pi ON p.id = pi.product_id
WHERE p.gender = 'men'
  AND b.name = 'Nike'
  AND c.name = 'Running'
  AND pi.is_primary = TRUE
